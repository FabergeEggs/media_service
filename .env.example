# Media Service — environment variables
#
# Copy to `.env` and adjust. All names below correspond to reads in
# `config/runtime.exs` (prod/release) and `config/dev.exs` (iex -S mix).
# The release binary refuses to boot in prod without DATABASE_URL and
# SECRET_KEY_BASE.

# ---- Phoenix / HTTP ---------------------------------------------------------

# Must be set to any non-empty value for the release to start the HTTP server.
# `bin/server` and `bin/entrypoint` already set this; set it yourself only if
# you invoke `bin/media_service start` manually.
PHX_SERVER=true

# Bandit listens on this port. The Dockerfile exposes 8000; in local iex it
# defaults to 4000.
PORT=8000

# 64+ random chars. Generate with `mix phx.gen.secret`.
SECRET_KEY_BASE=replace_me_with_64_char_random_string_from_mix_phx_gen_secret_xxxxx

# ---- Database ---------------------------------------------------------------

# Ecto URL: `ecto://USER:PASSWORD@HOST:PORT/DATABASE`.
# Required in prod, optional in dev (dev.exs has hard-coded localhost fallback).
DATABASE_URL=ecto://media_user:change_me_media@localhost:5433/media_db

# Optional: IPv6 Postgres connection. Empty/unset = IPv4.
ECTO_IPV6=

# Optional: Ecto pool size. Default: 10.
POOL_SIZE=10

# ---- S3 / MinIO -------------------------------------------------------------
#
# runtime.exs reads either the `S3_*` names or the `MINIO_*` aliases.
# Inside the Fabergé compose, the infra `.env` defines MINIO_* — the media
# container picks up S3_ACCESS_KEY_ID / S3_SECRET_ACCESS_KEY (which we set in
# mega-compose.yaml from MINIO_ROOT_*).

# Hostname as reachable from the media container — inside compose this is
# `minio`; from the host machine use `localhost`.
MINIO_HOST=minio
S3_HOST=

# Port on MINIO_HOST. Must match the container's API port (not the console).
MINIO_API_PORT=9000
S3_PORT=

# `http://` for plain HTTP MinIO, `https://` for real S3.
S3_SCHEME=http://

# Credentials. In compose these get wired from MINIO_ROOT_USER/PASSWORD.
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=change_me_password
MINIO_ROOT_USER=
MINIO_ROOT_PASSWORD=

# Bucket name. minio-init creates it on first boot.
MEDIA_S3_BUCKET=media
S3_BUCKET=

# Region string — not functionally used by MinIO but AWS SigV4 requires it.
S3_REGION=us-east-1

# ---- S2S authentication (shared secrets; replaced by Keycloak JWT later) ----
#
# One token per calling service. The media service's S2SAuth plug matches the
# `X-Service-Token` header against this list and puts the matching service
# name into conn.assigns.caller_service for audit.
#
# Two accepted formats:
#   1) CSV: `service:token,service:token`
#   2) JSON: `{"service":"token",...}`
#
# Each consuming service (profile, project, feed, response) must receive its
# own token through its own env var and send it as `X-Service-Token` on every
# request to media.
MEDIA_SERVICE_TOKENS=profile-service:change_me_profile,project-service:change_me_project,feed-service:change_me_feed,response-service:change_me_response

# ---- Optional: clustering ---------------------------------------------------

# DNS query for libcluster-style node discovery. Empty = no cluster.
DNS_CLUSTER_QUERY=

